  text-decoration: none;
}
.btn-outline:hover {
  border-color: var(--accent-teal);
  color: var(--accent-teal);
  transform: translateY(-2px);
}

@media (max-width: 1200px) {
  .mega-menu {
    padding: 20px 16px;
