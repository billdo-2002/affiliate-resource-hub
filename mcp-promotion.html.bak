  text-decoration: none;
}
.btn-teal:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 15px rgba(0, 200, 150, 0.4);
}
.btn-outline {
  background: transparent;
  color: var(--text-white);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 12px 24px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
