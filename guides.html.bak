    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 16px;
    display: grid !important;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  .mega-navy-title {
    grid-column: 1 / -1;
  }
  .mega-asset-card {
    margin-bottom: 0 !important;
  }
}

</style>
